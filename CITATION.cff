type: dataset
title: >-
  From Clause-Chaining to Parataxis: Intergenerational Variation in Clause
  Linkage Strategies among Kakataibo Speakers — Data and Code
authors:
  - family-names: Zariquiey
    given-names: Roberto
    affiliation: "Pontificia Universidad Católica del Perú"
    orcid: ""
